# =============================================================================
# cli2agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments; uncomment to enable.

# -----------------------------------------------------------------------------
# Authentication (choose one method)
# -----------------------------------------------------------------------------

# Option 1: Anthropic API Key (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: custom API endpoint (LiteLLM, OpenRouter, etc.)
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Option 2: OAuth Token (Claude Pro/Max subscribers)
# Mount ~/.config/claude/auth.json into the container instead, or set:
# CLAUDE_AUTH_TOKEN_PATH=/home/agent/.config/claude/auth.json

# Option 3: Amazon Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# ANTHROPIC_BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# Option 4: Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=us-east5

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# CLI2AGENT_PORT=3000
# CLI2AGENT_HOST=0.0.0.0
# CLI2AGENT_API_KEY=optional-api-key-for-server-auth
# CLI2AGENT_WORKSPACE=/workspace
# CLI2AGENT_DEFAULT_MODEL=
# CLI2AGENT_DEFAULT_MAX_TURNS=25
# CLI2AGENT_MAX_CONCURRENT=1
# CLI2AGENT_QUEUE_TIMEOUT=30000          # Max time (ms) a request waits in the concurrency queue
# CLI2AGENT_REQUEST_TIMEOUT=300000
# CLI2AGENT_MAX_SESSIONS=100

# -----------------------------------------------------------------------------
# Docker / Compose
# -----------------------------------------------------------------------------

# Workspace path mounted into the container (default: ./workspace)
# WORKSPACE_PATH=./workspace

# Match container user to your host UID/GID for correct file permissions
# HOST_UID=1000
# HOST_GID=1000
