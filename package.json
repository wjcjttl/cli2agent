{
  "name": "cli2agent",
  "version": "0.3.3",
  "description": "Self-hosted service that wraps AI coding CLIs (Claude Code, Codex, Gemini) as HTTP + SSE + MCP endpoints. Resilient access layer for AI-powered tools and integrations.",
  "license": "MIT",
  "author": "cli2agent contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjcjttl/cli2agent.git"
  },
  "homepage": "https://github.com/wjcjttl/cli2agent",
  "bugs": {
    "url": "https://github.com/wjcjttl/cli2agent/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-api",
    "claude-code-headless",
    "claude-code-docker",
    "claude-api-key",
    "ai-coding-agent",
    "self-hosted",
    "api",
    "agent",
    "docker",
    "sse",
    "streaming",
    "mcp",
    "model-context-protocol",
    "bedrock",
    "vertex-ai",
    "codex",
    "gemini-cli"
  ],
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^6.1.0",
    "openapi-types": "^12.1.3",
    "pino": "^9.14.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
